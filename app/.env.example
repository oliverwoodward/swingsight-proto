# SwingSight app — public runtime config.
# Copy to `.env` (Expo loads it automatically) before building the dev client.
#
# ONLY public values live here. EXPO_PUBLIC_* vars are inlined into the JS bundle
# and are NOT secret. The service-role key, R2 secrets and Anthropic key live ONLY
# in the worker / Edge Functions — never in the app.

# Your Supabase project URL, e.g. https://abcdefgh.supabase.co
EXPO_PUBLIC_SUPABASE_URL=

# Your Supabase anon (public) key — safe to ship; RLS protects the data.
EXPO_PUBLIC_SUPABASE_ANON_KEY=
