{
  "expo": {
    "name": "SwingSight",
    "slug": "swingsight",
    "owner": "swingsight",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "swingsight",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.swingsight.proto",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "SwingSight needs your camera to record your golf swing.",
        "NSMicrophoneUsageDescription": "SwingSight records audio with your swing video.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.swingsight.proto",
      "permissions": ["android.permission.CAMERA", "android.permission.RECORD_AUDIO"],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-video",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "d19293ab-2782-47de-9934-d7f0f775d6b6"
      }
    }
  }
}
