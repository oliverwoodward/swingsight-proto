# Copy to .env for local runs. In production these are Cloud Run env vars / secrets.
LOG_LEVEL=INFO

# Shared bearer token the on-swing-insert Edge Function presents to /analyze.
# Must equal the Edge Function's WORKER_INVOKER_TOKEN secret. Empty = no auth (local).
WORKER_INVOKER_TOKEN=

# Cloudflare R2 (S3-compatible). EU jurisdiction endpoint:
#   https://<account_id>.eu.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=swingsight-proto
R2_ENDPOINT=

# Supabase (service-role key — server-side only, never shipped to the app)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Claude Haiku 4.5 coaching call)
ANTHROPIC_API_KEY=
COACHING_MODEL=claude-haiku-4-5
