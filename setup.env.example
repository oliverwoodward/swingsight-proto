# ===========================================================================
# SwingSight Phase 2 — provisioning values (fill this in, then run ./scripts/setup.sh)
# ===========================================================================
# Copy this file to `setup.env`, fill in what you can, and run ./scripts/setup.sh.
# Anything you leave blank, the script will PROMPT you for. The two SECRET_* values
# are auto-generated if left blank. `setup.env` is gitignored — it holds secrets.
#
# Where each value comes from is noted inline. Locked choices for this project:
# Supabase region EU-West (Ireland), R2 EU jurisdiction, project+bucket swingsight-proto.

# --- Supabase -------------------------------------------------------------
# Create the project at supabase.com (region: West EU (Ireland)).
# Settings → General gives the ref; Settings → API gives the URL + anon key.
SUPABASE_PROJECT_REF=          # e.g. abcdefghijklmnopqrst
SUPABASE_URL=                  # https://<ref>.supabase.co
SUPABASE_ANON_KEY=             # the "anon public" key (safe to ship in the app)

# --- Cloudflare R2 --------------------------------------------------------
# Create bucket `swingsight-proto` (EU jurisdiction), then an S3 API token
# (Object Read & Write, scoped to that bucket). See supabase/r2/README.md.
R2_ACCOUNT_ID=                 # Cloudflare account id
R2_ACCESS_KEY_ID=              # from the R2 S3 API token
R2_SECRET_ACCESS_KEY=          # from the R2 S3 API token
R2_BUCKET=swingsight-proto     # default is fine
R2_ENDPOINT=                   # blank → auto: https://<acct>.eu.r2.cloudflarestorage.com

# --- Shared secrets (leave BLANK to auto-generate) ------------------------
# WEBHOOK_SECRET authenticates the DB trigger → on-swing-insert Edge Function.
# INVOKER_TOKEN authenticates on-swing-insert → the Cloud Run worker (/analyze).
WEBHOOK_SECRET=
INVOKER_TOKEN=

# --- Worker (Phase 3 — leave blank for Phase 2) ---------------------------
# Set once the Cloud Run worker is deployed; until then the webhook safely
# no-ops the dispatch (the Phase-2 checkpoint still proves the wiring → 501).
WORKER_URL=

# --- Checkpoint -----------------------------------------------------------
SAMPLE_CLIP=~/Code/Swing_Prototype/data/videos/IMG_5736.mov
